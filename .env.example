# Shared secret between GitHub Actions and /api/tick endpoint (timing-safe comparison)
TICK_SECRET=your-secret-here

# Vestaboard cloud API token (get from web.vestaboard.com → API section)
VESTABOARD_API_TOKEN=your-token-here

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (secret; server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: enable toroidal edge wrapping (default: true)
# WRAP_EDGES=true
